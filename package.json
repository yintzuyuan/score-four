{
  "name": "score-four",
  "version": "0.1.0",
  "description": "方垛式四子棋 — 3D Score Four game with Three.js",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.{js,css,html}\" \"tests/**/*.js\" \"*.{js,json,md,yml}\"",
    "format:check": "prettier --check \"src/**/*.{js,css,html}\" \"tests/**/*.js\" \"*.{js,json,md,yml}\"",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test tests/e2e/play.spec.js",
    "test:e2e:ui": "playwright test --ui",
    "test:visual": "playwright test tests/e2e/visual.spec.js",
    "test:visual:update": "playwright test tests/e2e/visual.spec.js --update-snapshots"
  },
  "dependencies": {
    "three": "0.160.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.59.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.0.0",
    "prettier": "^3.3.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
